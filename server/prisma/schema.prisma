generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  MANAGER
}

enum ProductStatus {
  ACTIVE
  INACTIVE
}

enum PaymentMethod {
  CASH
  UPI
  CARD
}

enum PaymentStatus {
  PAID
  UNPAID
}

enum OrderStatus {
  PENDING
  COMPLETED
  CANCELLED
}

enum InventoryAction {
  ADD
  REMOVE
  ADJUST
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(MANAGER)
  createdAt DateTime @default(now())

  @@map("users")
}

model Category {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  createdAt DateTime  @default(now())
  products  Product[]

  @@map("categories")
}

model Product {
  id              Int           @id @default(autoincrement())
  name            String
  sku             String?
  categoryId      Int
  price           Decimal       @db.Decimal(10, 2)
  image           String?
  description     String?
  stock           Int           @default(0)
  preparationTime Int?
  isAvailable     Boolean       @default(true)
  displayOrder    Int           @default(0)
  status          ProductStatus @default(ACTIVE)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  category   Category    @relation(fields: [categoryId], references: [id])
  orderItems OrderItem[]

  @@map("products")
}

model Order {
  id            Int           @id @default(autoincrement())
  orderNumber   String        @unique
  token         Int
  paymentMethod PaymentMethod
  paymentStatus PaymentStatus @default(PAID)
  orderStatus   OrderStatus   @default(COMPLETED)
  subtotal      Decimal       @db.Decimal(10, 2)
  discount      Decimal       @default(0) @db.Decimal(10, 2)
  gst           Decimal       @db.Decimal(10, 2)
  total         Decimal       @db.Decimal(10, 2)
  notes         String?
  createdAt     DateTime      @default(now())

  items OrderItem[]

  @@map("orders")
}

model OrderItem {
  id        Int     @id @default(autoincrement())
  orderId   Int
  productId Int
  quantity  Int
  price     Decimal @db.Decimal(10, 2)

  order   Order   @relation(fields: [orderId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@map("order_items")
}

model Inventory {
  id            Int      @id @default(autoincrement())
  name          String
  stock         Int      @default(0)
  minimumStock  Int      @default(0)
  unit          String
  purchasePrice Decimal? @db.Decimal(10, 2)
  supplierName  String?
  remarks       String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  history InventoryHistory[]

  @@map("inventory")
}

model InventoryHistory {
  id            Int             @id @default(autoincrement())
  inventoryId   Int
  action        InventoryAction
  quantity      Int
  previousStock Int
  newStock      Int
  remarks       String?
  createdAt     DateTime        @default(now())

  inventory Inventory @relation(fields: [inventoryId], references: [id])

  @@map("inventory_history")
}

model Settings {
  id            Int     @id @default(autoincrement())
  cafeName      String  @default("CafeFlow")
  address       String?
  phone         String?
  email         String?
  gstNumber     String?
  logo          String?
  printerWidth  Int     @default(80)
  taxPercentage Decimal @default(5.0) @db.Decimal(5, 2)
  receiptFooter String?
  openingTime   String?
  closingTime   String?
  currency      String  @default("₹")

  @@map("settings")
}
